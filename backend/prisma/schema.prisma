generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  email          String          @unique
  username       String
  password       String
  isAdmin        Boolean         @default(false)
  createdAt      DateTime        @default(now())

  typingSessions TypingSession[]
}

model TypingSession {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @db.ObjectId

  promptText      String
  // No typedText — each subsession has its own typedText

  startedAt       DateTime
  finishedAt      DateTime
  createdAt       DateTime     @default(now())

  // ML features — aggregated (mean) across all attempts
  avgDwellTime    Float
  avgFlightTime   Float
  typingSpeed     Float
  errorRate       Float
  backspaceCount  Float        // Float because it's now a mean across attempts
  sessionDuration Float

  user            User         @relation(fields: [userId], references: [id])
  subSessions     SubSession[]

  @@index([userId])
}

model SubSession {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  sessionId     String        @db.ObjectId
  attemptNumber Int

  typedText     String

  // Per-attempt ML features
  avgDwellTime    Float
  avgFlightTime   Float
  typingSpeed     Float
  errorRate       Float
  backspaceCount  Int
  sessionDuration Float

  // Raw keystrokes embedded — no separate KeystrokeEvent collection
  keystrokes    Json

  session       TypingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

